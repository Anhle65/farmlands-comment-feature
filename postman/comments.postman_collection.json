                        {
                            "name": "POST comments -invalid- -content too long-",
                            "event": [
                                {
                                    "listen": "prerequest",
                                    "script": {
                                        "type": "text/javascript",
                                        "exec": [
                                            "// Build a 1001-char string in a pre-request hook instead of inlining 1001 'a's in the body.",
                                            "pm.variables.set(\"longContent\", \"a\".repeat(1001));"
                                        ]
                                    }
                                },
                                {
                                    "listen": "test",
                                    "script": {
                                        "type": "text/javascript",
                                        "exec": [
                                            "pm.test(\"Status code is 400 Bad Request\", function () {",
                                            "    pm.response.to.have.status(400);",
                                            "});",
                                            "",
                                            "pm.test(\"Error message mentions the length limit\", function () {",
                                            "    pm.expect(pm.response.text()).to.match(/1000/);",
                                            "});"
                                        ]
                                    }
                                }
                            ],
                            "request": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"authorId\": \"55555555-5555-5555-5555-555555555555\",\n    \"authorName\": \"Anh\",\n    \"content\": \"{{longContent}}\"\n}"
                                },
                                "url": {
                                    "raw": "{{BASE_URL}}/comments",
                                    "host": [
                                        "{{BASE_URL}}"
                                    ],
                                    "path": [
                                        "comments"
                                    ]
                                },
                                "description": "Content > 1000 chars. Expected: 400. The pre-request script builds a 1001-char string and exposes it as {{longContent}}."
                            },
                            "response": []
                        },
